---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getResume } from "../../lib/content";
import { RESUME_TRACKS } from "../../content/config";
import dayjs from "dayjs";

export async function getStaticPaths() {
  return RESUME_TRACKS.map((track) => ({ params: { track } }));
}

const { track } = Astro.params as { track: (typeof RESUME_TRACKS)[number] };
const data = await getResume(track);

if (!data) {
  return Astro.redirect("/404");
}

const { entry, experience, projects } = data;
const { Content } = await entry.render();

const perspectiveKey: "hardware" | "software" | null =
  track === "hardware" ? "hardware" : track === "software" ? "software" : null;

function fmtRange(start: Date, end?: Date, current?: boolean) {
  const s = dayjs(start).format("YYYY.MM");
  if (current) return `${s} — Present`;
  if (end) return `${s} — ${dayjs(end).format("YYYY.MM")}`;
  return s;
}
---

<BaseLayout title={entry.data.title} sideBarActiveItemID="resume">
  {/* HERO */}
  <header class="mb-10">
    <h1 class="text-4xl md:text-5xl font-bold">{entry.data.title}</h1>
    {entry.data.tagline && (
      <p class="text-lg md:text-xl opacity-80 mt-3">{entry.data.tagline}</p>
    )}

    {entry.data.contact && (
      <div class="flex flex-wrap gap-3 mt-5">
        {entry.data.contact.email && (
          <a href={`mailto:${entry.data.contact.email}`} class="btn btn-sm btn-outline">
            ✉ Email
          </a>
        )}
        {entry.data.contact.github && (
          <a href={entry.data.contact.github} target="_blank" class="btn btn-sm btn-outline">
            GitHub ↗
          </a>
        )}
        {entry.data.contact.linkedin && (
          <a href={entry.data.contact.linkedin} target="_blank" class="btn btn-sm btn-outline">
            LinkedIn ↗
          </a>
        )}
      </div>
    )}

    <div class="tabs tabs-boxed w-fit mt-6">
      {RESUME_TRACKS.map((t) => (
        <a href={`/resume/${t}`} class={`tab ${t === track ? "tab-active" : ""}`}>
          {t}
        </a>
      ))}
    </div>
  </header>

  {/* IMPACT NUMBERS */}
  {entry.data.highlights && entry.data.highlights.length > 0 && (
    <section class="mb-12">
      <div class="grid grid-cols-2 md:grid-cols-3 gap-3">
        {entry.data.highlights.map((h) => (
          <div class="rounded-xl border border-base-300 p-4 bg-base-100">
            <div class="text-2xl md:text-3xl font-bold text-primary tracking-tight">
              {h.value}
            </div>
            <div class="text-sm font-semibold mt-1">{h.label}</div>
            {h.note && <div class="text-xs opacity-60 mt-1">{h.note}</div>}
          </div>
        ))}
      </div>
    </section>
  )}

  {/* SUMMARY */}
  {entry.data.summary && (
    <section class="mb-12">
      <p class="text-base leading-relaxed">{entry.data.summary}</p>
    </section>
  )}

  {/* EXPERIENCE */}
  {experience.length > 0 && (
    <section class="mb-12">
      <h2 class="text-2xl font-bold mb-5">Experience</h2>
      <ol class="relative border-l-2 border-base-300 ml-2 space-y-8">
        {experience.map((exp) => {
          const persp = perspectiveKey ? exp.data.perspectives?.[perspectiveKey] : null;
          const summary =
            persp?.summary ??
            exp.data.perspectives?.software?.summary ??
            exp.data.perspectives?.hardware?.summary;
          const highlights =
            persp?.highlights ?? [
              ...(exp.data.perspectives?.hardware?.highlights ?? []),
              ...(exp.data.perspectives?.software?.highlights ?? []),
            ];
          return (
            <li class="pl-6 relative">
              <span
                class={`absolute -left-[9px] top-1.5 w-4 h-4 rounded-full border-2 border-base-300 ${
                  exp.data.current ? "bg-primary" : "bg-base-100"
                }`}
              ></span>

              <div class="flex flex-wrap items-baseline justify-between gap-2">
                <div>
                  <span class="font-bold text-lg">{exp.data.role}</span>
                  <span class="opacity-70"> @ {exp.data.company}</span>
                  {exp.data.current && (
                    <span class="badge badge-primary badge-sm ml-2 align-middle">Current</span>
                  )}
                </div>
                <div class="text-sm opacity-70 font-mono">
                  {fmtRange(exp.data.startDate, exp.data.endDate, exp.data.current)}
                  {exp.data.location && <span class="opacity-80"> · {exp.data.location}</span>}
                </div>
              </div>

              {summary && <p class="mt-2 opacity-90">{summary}</p>}

              {highlights.length > 0 && (
                <ul class="mt-2 space-y-1 list-disc ml-5 marker:opacity-50">
                  {highlights.map((h) => (
                    <li class="opacity-90">{h}</li>
                  ))}
                </ul>
              )}

              {exp.data.stack && exp.data.stack.length > 0 && (
                <div class="mt-3 flex flex-wrap gap-1">
                  {exp.data.stack.map((s) => (
                    <span class="badge badge-outline badge-sm">{s}</span>
                  ))}
                </div>
              )}
            </li>
          );
        })}
      </ol>
    </section>
  )}

  {/* PROJECTS */}
  {projects.length > 0 && (
    <section class="mb-12">
      <h2 class="text-2xl font-bold mb-5">Selected projects</h2>
      <div class="grid md:grid-cols-2 gap-3">
        {projects.map((p) => (
          <a
            href={`/projects/${p.slug}`}
            class="block rounded-xl border border-base-300 p-4 bg-base-100 hover:shadow-md transition"
          >
            <div class="font-bold">{p.data.title}</div>
            {p.data.company && (
              <div class="text-xs text-primary font-semibold mt-1">@ {p.data.company}</div>
            )}
            <p class="text-sm opacity-80 mt-2">{p.data.description}</p>
          </a>
        ))}
      </div>
    </section>
  )}

  {/* SKILLS */}
  {entry.data.skills && entry.data.skills.length > 0 && (
    <section class="mb-12">
      <h2 class="text-2xl font-bold mb-5">Skills</h2>
      <div class="space-y-3">
        {entry.data.skills.map((g) => (
          <div>
            <div class="text-sm font-semibold opacity-70 mb-2">{g.group}</div>
            <div class="flex flex-wrap gap-1.5">
              {g.items.map((item) => (
                <span class="badge badge-outline">{item}</span>
              ))}
            </div>
          </div>
        ))}
      </div>
    </section>
  )}

  {/* EDUCATION */}
  {entry.data.education && entry.data.education.length > 0 && (
    <section class="mb-12">
      <h2 class="text-2xl font-bold mb-5">Education</h2>
      {entry.data.education.map((ed) => (
        <div class="mb-2">
          <div class="font-bold">{ed.school}</div>
          {ed.degree && <div class="opacity-80">{ed.degree}</div>}
          {(ed.startDate || ed.endDate) && (
            <div class="text-sm opacity-70 font-mono">
              {ed.startDate ? dayjs(ed.startDate).format("YYYY.MM") : ""}
              {ed.endDate ? ` — ${dayjs(ed.endDate).format("YYYY.MM")}` : ""}
            </div>
          )}
        </div>
      ))}
    </section>
  )}

  {/* FREE-FORM BODY */}
  <article class="prose max-w-none">
    <Content />
  </article>
</BaseLayout>
