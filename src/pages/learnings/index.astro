---
import BaseLayout from "../../layouts/BaseLayout.astro";
import HorizontalCard from "../../components/HorizontalCard.astro";
import { getLearnings } from "../../lib/content";

const entries = await getLearnings();
---

<BaseLayout title="Learnings" sideBarActiveItemID="learnings">
  <div class="mb-5">
    <div class="text-3xl w-full font-bold">Learnings</div>
    <p class="opacity-70 mt-2">Short notes and things I'm currently studying.</p>
  </div>

  {entries.length === 0 ? (
    <p class="opacity-70">No entries yet.</p>
  ) : (
    entries.map((e) => (
      <>
        <HorizontalCard
          title={e.data.title}
          desc={e.data.description}
          url={`/learnings/${e.slug}`}
          target="_self"
          tags={e.data.tags}
          date={e.data.pubDate}
        />
        <div class="divider my-0" />
      </>
    ))
  )}
</BaseLayout>
