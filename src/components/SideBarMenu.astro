---
import { getBlogByCategory, getProjects } from "../lib/content";
import { BLOG_CATEGORIES } from "../content/config";

const { sideBarActiveItemID } = Astro.props;
const activeClass = "bg-base-300";

const grouped = await getBlogByCategory();
const cats = BLOG_CATEGORIES
  .map((c) => ({ name: c, count: grouped.get(c)?.length ?? 0 }))
  .filter((c) => c.count > 0);

const projects = await getProjects();
const kinds = [
  { id: "company", label: "Company", count: projects.filter((p) => p.data.kind === "company").length },
  { id: "side", label: "Side", count: projects.filter((p) => p.data.kind === "side").length },
  { id: "open-source", label: "Open source", count: projects.filter((p) => p.data.kind === "open-source").length },
].filter((k) => k.count > 0);
---

<ul class="menu grow shrink menu-md overflow-y-auto">
    <li><a class="py-3 text-base" id="home" href="/">Home</a></li>
    <li><a class="py-3 text-base" id="resume" href="/resume/main">Resume</a></li>
    <li>
        <details open>
            <summary class="py-3 text-base" id="projects">Projects</summary>
            <ul>
                <li><a class="py-2 text-sm whitespace-nowrap" href="/projects">All projects</a></li>
                {kinds.map((k) => (
                    <li>
                        <a class="py-2 text-sm flex justify-between items-center" href={`/projects#${k.id}`}>
                            <span class="truncate">{k.label}</span>
                            <span class="opacity-50 ml-2">{k.count}</span>
                        </a>
                    </li>
                ))}
            </ul>
        </details>
    </li>
    <li>
        <details open>
            <summary class="py-3 text-base" id="blog">Blog</summary>
            <ul>
                <li><a class="py-2 text-sm whitespace-nowrap" href="/blog/">All posts</a></li>
                {cats.map((c) => (
                    <li>
                        <a class="py-2 text-sm flex justify-between items-center" href={`/blog/category/${c.name}`}>
                            <span class="truncate">{c.name}</span>
                            <span class="opacity-50 ml-2">{c.count}</span>
                        </a>
                    </li>
                ))}
            </ul>
        </details>
    </li>
    <li><a class="py-3 text-base" id="learnings" href="/learnings">Learnings</a></li>
    <li><a class="py-3 text-base" id="about" href="/about">About</a></li>
</ul>

<script define:vars={{ sideBarActiveItemID: sideBarActiveItemID, activeClass: activeClass }}>
const activeItemElem = document.getElementById(sideBarActiveItemID);
activeItemElem && activeItemElem.classList.add(activeClass);
</script>
