---
import { Image } from "astro:assets";
import dayjs from "dayjs";

const { title, img, desc, url, badge, tags, target = "_blank", date, subtitle } = Astro.props;
const tag_url = url.split("/").slice(0, -1).join("/") + "/tag";
const displayDate = date ? dayjs(date).format("YYYY.MM.DD") : null;
---

<div
  class="rounded-lg bg-base-100 hover:shadow-xl transition ease-in-out hover:scale-[102%]"
>
  <a href={url} target={target}>
    <div class="hero-content flex-col md:flex-row">
      {
        img && (
          <Image
            src={img}
            width={750}
            height={422}
            format="webp"
            alt={title}
            class="max-w-full md:max-w-[13rem] rounded-lg"
          />
        )
      }
      <div class="grow w-full">
        <div class="flex items-baseline justify-between gap-2 flex-wrap">
          <h1 class="text-xl font-bold">
            {title}
            {badge && <div class="badge badge-secondary mx-2">{badge}</div>}
          </h1>
          {displayDate && (
            <time class="text-sm opacity-60 shrink-0">{displayDate}</time>
          )}
        </div>
        {subtitle && (
          <div class="text-sm font-semibold text-primary mt-1">@ {subtitle}</div>
        )}
        <p class="py-1 text-1xl">{desc}</p>
        <div class="card-actions justify-end">
          {
            tags &&
              tags.map((tag) => (
                <a href={`${tag_url}/${tag}`} class="badge badge-outline">
                  {tag}
                </a>
              ))
          }
        </div>
      </div>
    </div>
  </a>
</div>
